{
  "name": "github-project-info-mcp",
  "version": "0.1.0",
  "description": "MCP server + browser client + Cloudflare Worker for reading public GitHub Projects (v2) boards without authentication — official REST API for metadata, undocumented-but-public fallbacks for item-level data (status, fields, story points) where GitHub's official API requires a token.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "github-project-info-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint src tests",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "mcp-worker:dev": "wrangler dev -c wrangler.mcp.toml",
    "mcp-worker:deploy": "wrangler deploy -c wrangler.mcp.toml"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "github",
    "github-projects",
    "projects-v2"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "3.25.76",
    "agents": "0.16.2"
  },
  "devDependencies": {
    "@types/node": "22.13.4",
    "typescript": "5.7.3",
    "tsx": "4.20.6",
    "vitest": "3.2.6",
    "eslint": "9.39.4",
    "@typescript-eslint/eslint-plugin": "8.24.0",
    "@typescript-eslint/parser": "8.24.0",
    "@eslint/js": "9.39.4",
    "typescript-eslint": "8.24.0",
    "wrangler": "4.107.0",
    "@cloudflare/workers-types": "4.20260101.0"
  }
}
